:root{font-family:system-ui,-apple-system,Segoe UI,Roboto,Arial,sans-serif}body{margin:0;line-height:1.6}a{text-decoration:none}a:hover{text-decoration:underline}.container{max-width:980px;margin:0 auto;padding:16px}.site-header{border-bottom:1px solid #eee}.nav{display:flex;gap:12px;align-items:center;padding:12px 0;flex-wrap:wrap}.nav a{font-weight:600}.grid{display:grid;grid-template-columns:1fr;gap:16px}@media(min-width:820px){.grid{grid-template-columns:1fr 1fr}}.card{border:1px solid #eee;border-radius:10px;padding:14px}.meta{color:#555;font-size:.9rem}.tag{display:inline-block;border:1px solid #ddd;border-radius:999px;padding:2px 10px;font-size:.85rem;margin-right:8px}.hero{width:100%;border-radius:12px;margin:12px 0}.toc{border:1px solid #eee;border-radius:10px;padding:12px;margin:16px 0}.btn{border:1px solid #ddd;border-radius:10px;padding:8px 12px;background:0 0;cursor:pointer}.status{font-size:.9rem;color:#2d6a2d;margin-left:8px}